# Claude Vision Video Analyzer - Configuration

# ========== REQUIRED ==========
# Get your API key from: https://console.anthropic.com/
# 1. Go to https://console.anthropic.com/
# 2. Sign up with your email
# 3. Navigate to API Keys
# 4. Click "Create Key"
# 5. Copy the key here
ANTHROPIC_API_KEY=your_api_key_here

# ========== OPTIONAL ==========
# Frame extraction interval in seconds (default: 2)
FRAME_INTERVAL=2

# Output directory for frames and analysis (default: output_frames)
OUTPUT_DIR=output_frames

# Claude model (default: claude-3-5-sonnet-20241022 - recommended)
# Options:
#   claude-3-5-sonnet-20241022 - Best balance (recommended)
#   claude-3-opus-20240229 - Highest quality
#   claude-3-sonnet-20240229 - Fast and capable
MODEL=claude-3-5-sonnet-20241022

# Maximum tokens for response (default: 1024)
MAX_TOKENS=1024

# Whether to keep frames after analysis (default: true)
KEEP_FRAMES=true

# ========== ADVANCED ==========
# Anthropic API URL (usually not needed)
# ANTHROPIC_API_URL=https://api.anthropic.com

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

